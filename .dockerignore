# =============================================================================
# .dockerignore — 시크릿/누수 차단
# =============================================================================

# 시크릿 (절대 이미지에 포함 금지)
.env
.env.*
*.env
.env.local
.env.production
secrets/
credentials/
*.pem
*.key
*.crt
.git-credentials

# WVB Personal Data Protection (CLAUDE.md - personal-data-protection.md)
wiki/_personal/
memory/SOUL/
**/USER.md
**/SOUL.md
**/ACCESS_POLICY.md
**/HEARTBEAT.md

# Git 메타 (entrypoint.sh가 환경변수로 wiki repo 처리, submodule 미사용)
.git/
.gitignore
.github/

# 개발/빌드 산출물
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
npm-debug.log
yarn-error.log
dist/
build/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 로컬 테스트
test-data/
tmp/
*.log
*.local

# 문서 (Railway 런타임 불필요)
docs/
# 문서 *.md 차단 (Railway 런타임 불필요) — 단 Hermes skill 정의는 보존
*.md
!README.md
!skills/**/*.md
!**/SKILL.md
LICENSE
CHANGELOG.md

# Hermes 로컬 세션 (개인 PC 테스트 흔적)
.hermes/
~/.hermes/

# WVB 본 repo의 nested CC artifacts
.claude/
.bkit/
notifications/
content/
knowledge/
output/
