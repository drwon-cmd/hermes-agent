# =============================================================================
# Hermes Agent Config Template (WVB 24/7 비서실장) — Phase 1 Minimum
# 위치(런타임): /opt/data/config.yaml (Railway volume)
# 위치(이미지): /opt/wvb-bootstrap/config.yaml.template
# Bootstrap: entrypoint.sh가 첫 부팅 시 ${VAR} 치환하여 /opt/data로 복사
# =============================================================================
#
# 2026-05-16 cto-lead 11번째 + main 판단실수 정정 (3차):
#   - cto-lead 원본: 자체 명명 schema → Hermes 무시 → 401 fail
#   - main 1차 정정: anthropic/claude-opus-4.6 디폴트 → ❌ Plan §3.3 위배 (사용자
#     결정: Groq 무료 디폴트). cost-guard.md 위반. 즉시 롤백.
#   - main 2차 정정: OPENAI_BASE_URL=Groq → ❌ OPENAI_API_KEY가 Whisper STT용
#     (김실장 동일 key, 사용자 옵션 B 결정). Groq key로 변경 시 STT 영향. 즉시 롤백.
#   - 3차 정정 (현재): OpenRouter 무료 모델 (`:free` 접미사) 경유 → 무료 유지,
#     STT용 OPENAI_API_KEY 보존, 신규 OPENROUTER_API_KEY만 추가
#
# Phase 1 정책 (Plan §3.3 사용자 결정 그대로):
#   - default model = Llama 3.3 70B via OpenRouter (:free 무료 티어)
#   - provider = openrouter (Hermes native 지원)
#   - 환경변수 OPENROUTER_API_KEY 신규 + OPENAI_API_KEY 그대로 (STT용)
#   - Anthropic은 escalation 전용 (Plan §5 한도 $10)
# =============================================================================

# -----------------------------------------------------------------------------
# Model — Google Gemini 2.5 Flash (무료, Hermes 공식 24/7 personal use 권장)
# 2026-05-16 4차 정정: OpenRouter :free → Gemini Flash
#   - OpenRouter :free 한도 분 20/일 50 = 비서 사용 burden ↑
#   - Gemini Flash 한도 분 15/일 1500 = generous quota
#   - 한국어 품질 우수, 신용카드 불필요
#   - Plan §3.3 정신 (무료 디폴트) 그대로 유지
# -----------------------------------------------------------------------------
model:
  default: "gemini-2.5-flash"
  provider: "gemini"

# -----------------------------------------------------------------------------
# Auxiliary models — 모두 Gemini Flash로 통일 (Anthropic 호출 0건 보장)
# -----------------------------------------------------------------------------
auxiliary:
  vision:
    provider: "gemini"
    model: "gemini-2.5-flash"
  web_extract:
    provider: "auto"  # TAVILY_API_KEY envvar 자동 감지 (Phase 4.5)
  session_search:
    provider: "gemini"
    model: "gemini-2.5-flash"
    max_concurrency: 2

# -----------------------------------------------------------------------------
# Platforms — Telegram (Phase 1)
# -----------------------------------------------------------------------------
platforms:
  telegram:
    reply_to_mode: "first"
    guest_mode: false

# -----------------------------------------------------------------------------
# Platform Toolsets — telegram 도구 명시 (browser 제외, web_search 활성)
# 2026-05-16 fix: 기본 preset 'hermes-telegram'은 browser 포함 → Chrome 없어서 fail
#   LLM이 browser_navigate 우선 선택 + Chrome 없음 에러
#   해결: browser 제외 + web (Tavily web_search) 유지 → LLM이 web_search 사용
# -----------------------------------------------------------------------------
platform_toolsets:
  telegram:
    - web         # web_search (Tavily) + web_extract
    - skills      # WVB skill 6개 사용
    - file        # 파일 접근
    - vision      # 이미지 분석
    - tts         # 음성 출력
    - todo        # 작업 추적
    - cronjob     # 일정 자동화
    - messaging   # 텔레그램 응답
    # browser 제외 (Chrome 없어서 fail)
    # terminal 제외 (Phase 1 보안 — 외부 명령 실행 차단)
    # image_gen 제외 (Phase 1 미사용)

# -----------------------------------------------------------------------------
# Telegram top-level
# -----------------------------------------------------------------------------
telegram:
  require_mention: false
  reactions: true

# -----------------------------------------------------------------------------
# Timezone (cron + log 일관성)
# -----------------------------------------------------------------------------
timezone: "Asia/Singapore"

# -----------------------------------------------------------------------------
# Display
# -----------------------------------------------------------------------------
display:
  language: "ko"

# -----------------------------------------------------------------------------
# Skills external directories — WVB 도메인 skill 발견
# 2026-05-16 fix (cto-lead 17번째 실수):
#   Hermes default scan = ~/.hermes/skills/ 만 (= /opt/data/.hermes/skills/)
#   entrypoint.sh가 /opt/data/skills/wvb/ 로 copy했지만 config.yaml 명시 안 함 → 미발견
#   → external_dirs 명시 (Hermes docs: "External dirs require explicit configuration")
# -----------------------------------------------------------------------------
skills:
  external_dirs:
    - /opt/data/skills/wvb

# -----------------------------------------------------------------------------
# WVB 도메인 정책 (envvar 처리, config.yaml 영향 없음)
#   - HERMES_EXTERNAL_SEND_MODE (CCO 게이트)
#   - ANTHROPIC_API_KEY (escalation 전용, 키워드 매칭 시)
#   - TAVILY_API_KEY (Hermes 환경변수 자동 인식, config 불필요)
# -----------------------------------------------------------------------------
