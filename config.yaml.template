# =============================================================================
# Hermes Agent Config Template (WVB 24/7 비서실장) — Phase 1 Minimum
# 위치(런타임): /opt/data/config.yaml (Railway volume)
# 위치(이미지): /opt/wvb-bootstrap/config.yaml.template
# Bootstrap: entrypoint.sh가 첫 부팅 시 ${VAR} 치환하여 /opt/data로 복사
# =============================================================================
#
# 2026-05-16 cto-lead 11번째 + main 판단실수 정정 (3차):
#   - cto-lead 원본: 자체 명명 schema → Hermes 무시 → 401 fail
#   - main 1차 정정: anthropic/claude-opus-4.6 디폴트 → ❌ Plan §3.3 위배 (사용자
#     결정: Groq 무료 디폴트). cost-guard.md 위반. 즉시 롤백.
#   - main 2차 정정: OPENAI_BASE_URL=Groq → ❌ OPENAI_API_KEY가 Whisper STT용
#     (김실장 동일 key, 사용자 옵션 B 결정). Groq key로 변경 시 STT 영향. 즉시 롤백.
#   - 3차 정정 (현재): OpenRouter 무료 모델 (`:free` 접미사) 경유 → 무료 유지,
#     STT용 OPENAI_API_KEY 보존, 신규 OPENROUTER_API_KEY만 추가
#
# Phase 1 정책 (Plan §3.3 사용자 결정 그대로):
#   - default model = Llama 3.3 70B via OpenRouter (:free 무료 티어)
#   - provider = openrouter (Hermes native 지원)
#   - 환경변수 OPENROUTER_API_KEY 신규 + OPENAI_API_KEY 그대로 (STT용)
#   - Anthropic은 escalation 전용 (Plan §5 한도 $10)
# =============================================================================

# -----------------------------------------------------------------------------
# Model — Google Gemini 2.5 Flash (무료, Hermes 공식 24/7 personal use 권장)
# 2026-05-16 4차 정정: OpenRouter :free → Gemini Flash
#   - OpenRouter :free 한도 분 20/일 50 = 비서 사용 burden ↑
#   - Gemini Flash 한도 분 15/일 1500 = generous quota
#   - 한국어 품질 우수, 신용카드 불필요
#   - Plan §3.3 정신 (무료 디폴트) 그대로 유지
# -----------------------------------------------------------------------------
model:
  default: "gemini-2.5-flash"
  provider: "gemini"

# -----------------------------------------------------------------------------
# Auxiliary models — 모두 Gemini Flash로 통일 (Anthropic 호출 0건 보장)
# -----------------------------------------------------------------------------
auxiliary:
  vision:
    provider: "gemini"
    model: "gemini-2.5-flash"
  web_extract:
    provider: "auto"  # TAVILY_API_KEY envvar 자동 감지 (Phase 4.5)
  session_search:
    provider: "gemini"
    model: "gemini-2.5-flash"
    max_concurrency: 2

# -----------------------------------------------------------------------------
# Platforms — Telegram (Phase 1)
# -----------------------------------------------------------------------------
platforms:
  telegram:
    reply_to_mode: "first"
    guest_mode: false

# -----------------------------------------------------------------------------
# Platform Toolsets — telegram 도구 명시 (browser 제외, web_search 활성)
# 2026-05-16 fix: 기본 preset 'hermes-telegram'은 browser 포함 → Chrome 없어서 fail
#   LLM이 browser_navigate 우선 선택 + Chrome 없음 에러
#   해결: browser 제외 + web (Tavily web_search) 유지 → LLM이 web_search 사용
# -----------------------------------------------------------------------------
platform_toolsets:
  telegram:
    - web         # web_search (Tavily) + web_extract
    - skills      # WVB skill 6개 사용
    - file        # 파일 접근
    - todo        # 작업 추적
    - cronjob     # 일정 자동화
    - send_message  # 텔레그램 응답 (공식 키: hermes-telegram preset 명시)
    - terminal    # 2026-05-16 Phase 6a 추가: setup.py 실행 + script run + file ops
                  # 사용자 결정 T1: 영구 허용. _personal/SOUL은 entrypoint.sh가 차단.
                  # Hermes user + 컨테이너 격리 + Volume /opt/data 한정으로 안전
    # browser 제외 (Chrome 없어서 fail)
    # image_gen 제외 (Phase 1 미사용)
    # 2026-05-16 22:30 Option B: vision/tts 제외 — 사용 빈도 낮음, token 절감 (~15-20K)
    # vision: 이미지 분석 — 필요 시 재추가 가능
    # tts: 음성 출력 — 텔레그램은 텍스트 위주, TTS 사용 케이스 거의 없음

# -----------------------------------------------------------------------------
# Web Search Backend — Tavily 명시 (자동 감지 보강)
# 근거: tools/web_tools.py L178 "1. web.backend from config.yaml"
# auto-detection priority: firecrawl → parallel → tavily → exa → searxng → brave-free → ddgs
# TAVILY_API_KEY envvar 자동 감지 가능하지만 명시로 안정성 ↑
# 2026-05-16 fix: main 5차 실수(`web:` 섹션 완전 제거)는 over-correction였음
# example에 없어도 source code에서 읽음 — v1.8 §11 자기 정정
# -----------------------------------------------------------------------------
web:
  backend: "tavily"

# -----------------------------------------------------------------------------
# Telegram top-level
# -----------------------------------------------------------------------------
telegram:
  require_mention: false
  reactions: true

# -----------------------------------------------------------------------------
# Session Reset (Telegram conversation context 누적 차단)
# -----------------------------------------------------------------------------
# 2026-05-16 22:30 Option A: idle_minutes 1440 (24h) → 360 (6h)
# Hermes cli-config.yaml.example L504-507 schema. default 24h는 비서 대화에 길음 —
# context 누적으로 token 폭증, 429 잦은 hit. 6h 후 idle reset으로 fresh context.
# session reset 시 봇이 memory에 중요 정보 save 후 context wipe (memory는 영구 보존).
# -----------------------------------------------------------------------------
session_reset:
  mode: both
  idle_minutes: 360   # 6시간 idle 후 reset
  at_hour: 4          # 매일 04:00 SGT reset

# -----------------------------------------------------------------------------
# Timezone (cron + log 일관성)
# -----------------------------------------------------------------------------
timezone: "Asia/Singapore"

# -----------------------------------------------------------------------------
# Display
# -----------------------------------------------------------------------------
display:
  language: "ko"

# -----------------------------------------------------------------------------
# Skills external directories — WVB 도메인 skill 발견
# 2026-05-16 fix (cto-lead 17번째 실수):
#   Hermes default scan = ~/.hermes/skills/ 만 (= /opt/data/.hermes/skills/)
#   entrypoint.sh가 /opt/data/skills/wvb/ 로 copy했지만 config.yaml 명시 안 함 → 미발견
#   → external_dirs 명시 (Hermes docs: "External dirs require explicit configuration")
# -----------------------------------------------------------------------------
skills:
  external_dirs:
    - /opt/data/skills/wvb

# -----------------------------------------------------------------------------
# WVB 도메인 정책 (envvar 처리, config.yaml 영향 없음)
#   - HERMES_EXTERNAL_SEND_MODE (CCO 게이트)
#   - ANTHROPIC_API_KEY (escalation 전용, 키워드 매칭 시)
#   - TAVILY_API_KEY (Hermes 환경변수 자동 인식, config 불필요)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# MCP Servers — Phase 6b (MS 365 통합, Plan v1.4 §Path B)
# -----------------------------------------------------------------------------
# 2026-05-16 추가: softeria/ms-365-mcp-server를 stdio subprocess로 등록.
# 활성 조건: Railway envvar 3개 모두 set 시 작동 (없으면 Hermes가 시작 시도 후 skip)
# - MS365_MCP_CLIENT_ID: Azure AD App registration의 Application (client) ID
# - MS365_MCP_TENANT_ID: Directory (tenant) ID
# - MS365_MCP_CLIENT_SECRET: Client Secret value (Certificates & secrets 탭)
# - MS365_MCP_TOKEN_CACHE_PATH: Volume 경로 (entrypoint Step 4.4가 디렉토리 생성)
# Scope: --org-mode (work account drwon@wiltvb.com용)
# 첫 사용 시 텔레그램에서 "MS 365 setup 해줘" → device code flow OAuth
# 검증: Hermes cli-config.yaml.example L777-790 schema
# -----------------------------------------------------------------------------
mcp_servers:
  ms365:
    command: ms-365-mcp-server
    args:
      # 2026-05-16 fix: Gemini 2.5 Flash paid Tier 1 한도 분당 1M input tokens 초과 사고.
      # softeria 200+ tools schema가 매 호출 system prompt에 다 들어가면서 폭증.
      # --preset comma-separated (README L491) 적용으로 30-50개 도구로 축소.
      # Scope (mail+calendar+files) = 사용자가 인증한 Mail.Read/Send + Calendars.Read +
      # Files.Read.All 권한과 정확히 매칭.
      - --preset
      # 2026-05-16 22:30 Option C: preset 더 축소 (calendar,files 제외)
      # 이유: 매 호출 ms365 tools schema가 system prompt 50-80K 점유 → 429 잦음
      # 효과: mail만 활성화 → tools ~30개 → 15개로 축소, ~25-40K 절감
      # Trade-off: Outlook 일정 (M2) + OneDrive 검색 (M3) 비활성화. 필요 시 즉시 재추가:
      #   변경: "mail" → "mail,calendar" 또는 "mail,calendar,files"
      # 사용자가 calendar/files 사용 빈도 보고 재조정 결정
      - mail
      - --org-mode  # work account (drwon@wiltvb.com) 지원
    env:
      MS365_MCP_CLIENT_ID: ${MS365_MCP_CLIENT_ID}
      MS365_MCP_TENANT_ID: ${MS365_MCP_TENANT_ID}
      MS365_MCP_CLIENT_SECRET: ${MS365_MCP_CLIENT_SECRET}
      MS365_MCP_TOKEN_CACHE_PATH: /opt/data/.ms365/token-cache.json
      MS365_MCP_SELECTED_ACCOUNT_PATH: /opt/data/.ms365/selected-account.json
      # README L505: Graph $top hard cap — 리스트 응답 크기 제한 (출력 token 절감)
      MS365_MCP_MAX_TOP: "15"
    timeout: 180
    connect_timeout: 60
